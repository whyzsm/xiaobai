{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loop.schema.json",
  "title": "Loop Spec",
  "type": "object",
  "required": [
    "kind",
    "version",
    "metadata",
    "schedule",
    "discovery",
    "handoff",
    "generator",
    "verification",
    "persistence",
    "budget",
    "humanGate"
  ],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "Loop" },
    "version": { "type": "integer", "minimum": 1 },
    "metadata": {
      "type": "object",
      "required": ["id", "name", "owner"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 }
      }
    },
    "schedule": {
      "type": "object",
      "required": ["type", "expression", "timezone"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "expression": { "type": "string", "minLength": 1 },
        "timezone": { "type": "string", "minLength": 1 }
      }
    },
    "discovery": {
      "type": "object",
      "required": ["skill", "sources"],
      "additionalProperties": false,
      "properties": {
        "skill": { "type": "string", "minLength": 1 },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/discoverySource" }
        }
      }
    },
    "orchestrator": {
      "type": "object",
      "required": ["agent"],
      "additionalProperties": false,
      "properties": {
        "agent": { "type": "string", "minLength": 1 }
      }
    },
    "handoff": {
      "type": "object",
      "required": ["strategy", "project", "worktreeRoot", "branchTemplate"],
      "additionalProperties": false,
      "properties": {
        "strategy": { "type": "string", "minLength": 1 },
        "project": { "type": "string", "minLength": 1 },
        "targetResolution": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required": { "type": "boolean" }
          }
        },
        "worktreeRoot": { "type": "string", "minLength": 1 },
        "branchTemplate": { "type": "string", "minLength": 1 }
      }
    },
    "generator": {
      "type": "object",
      "required": ["agent", "harness"],
      "additionalProperties": false,
      "properties": {
        "agent": { "type": "string", "minLength": 1 },
        "harness": { "type": "string", "minLength": 1 }
      }
    },
    "verification": {
      "type": "object",
      "required": ["evaluator", "requiredChecks", "allowSelfReview"],
      "additionalProperties": false,
      "properties": {
        "evaluator": { "type": "string", "minLength": 1 },
        "requiredChecks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "allowSelfReview": { "type": "boolean" }
      }
    },
    "persistence": {
      "type": "object",
      "required": ["memory", "outputs"],
      "additionalProperties": false,
      "properties": {
        "memory": {
          "type": "object",
          "required": ["stateFile", "inboxFile", "runLog"],
          "additionalProperties": false,
          "properties": {
            "stateFile": { "type": "string", "minLength": 1 },
            "inboxFile": { "type": "string", "minLength": 1 },
            "runLog": { "type": "string", "minLength": 1 }
          }
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/outputTarget" }
        }
      }
    },
    "budget": { "$ref": "#/$defs/budgetLimits" },
    "humanGate": {
      "type": "object",
      "required": ["requiredBefore", "reviewers"],
      "additionalProperties": false,
      "properties": {
        "requiredBefore": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "reviewers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "workflow": {
      "type": "object",
      "required": ["stages"],
      "additionalProperties": false,
      "properties": {
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/workflowStage" }
        }
      }
    }
  },
  "$defs": {
    "workflowStage": {
      "type": "object",
      "required": ["id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "gate": { "enum": ["automatic", "manual"] },
        "agent": { "type": "string", "minLength": 1 },
        "harness": { "type": "string", "minLength": 1 },
        "evaluator": { "type": "string", "minLength": 1 },
        "requiredChecks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "requiredBefore": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "discoverySource": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "connector": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "outputTarget": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "connector": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "budgetLimits": {
      "type": "object",
      "required": ["maxTokensPerRun", "maxRetriesPerTask", "maxParallelTasks"],
      "additionalProperties": false,
      "properties": {
        "maxTokensPerRun": { "type": "integer", "minimum": 1 },
        "maxTokensPerDay": { "type": "integer", "minimum": 1 },
        "maxCostPerDayUsd": { "type": "number", "exclusiveMinimum": 0 },
        "maxRetriesPerTask": { "type": "integer", "minimum": 0 },
        "maxParallelTasks": { "type": "integer", "minimum": 1 },
        "maxRunsPerDay": { "type": "integer", "minimum": 1 },
        "maxWallClockMinutesPerRun": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
