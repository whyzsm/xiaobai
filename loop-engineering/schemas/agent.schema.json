{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent.schema.json",
  "title": "Agent Spec",
  "type": "object",
  "required": ["kind", "id", "role", "instructions", "model"],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "Agent" },
    "id": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "stance": { "type": "string", "minLength": 1 },
    "instructions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "model": {
      "type": "object",
      "required": ["preference"],
      "additionalProperties": false,
      "properties": {
        "preference": { "type": "string", "minLength": 1 }
      }
    },
    "tools": {
      "type": "object",
      "required": ["allow"],
      "additionalProperties": false,
      "properties": {
        "allow": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
